{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "resolveJsonModule": true,
        "jsx": "preserve",
        "jsxImportSource": "astro",
        "paths": {
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"]
        }
    },
    "mdx": {
        "checkMdx": true
    }
}
